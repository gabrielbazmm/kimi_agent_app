{
  "version": "0.2.0",
  "configurations": [
    {
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "name": "Launch Agent Extension",
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "pnpm: install",
      "request": "launch",
      "type": "extensionHost"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Agent",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/${relativeFileDirname}/${fileBasenameNoExtension}.js",
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "pnpm: build"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Agent Web App",
      "url": "${defaultBuildRoot}",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "npm: dev",
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*"
      }
    }
  ]
}

